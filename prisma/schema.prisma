generator client {
    provider = "prisma-client"
    output   = "../generated"
}

datasource db {
    provider = "sqlite"
}

model Customer {
    id           String        @id @default(cuid())
    name         String
    email        String        @unique
    passwordHash String
    phone        String?
    vehicles     Vehicle[]
    appointments Appointment[]
    createdAt    DateTime      @default(now())
}

model Vehicle {
    id           String        @id @default(cuid())
    customerId   String
    make         String
    model        String
    year         Int
    licensePlate String        @unique
    customer     Customer      @relation(fields: [customerId], references: [id])
    appointments Appointment[]
}

model Dealership {
    id           String        @id @default(cuid())
    name         String
    address      String
    serviceBays  ServiceBay[]
    technicians  Technician[]
    appointments Appointment[]
}

model ServiceType {
    id              String        @id @default(cuid())
    name            String
    durationMinutes Int
    requiredSkill   String
    appointments    Appointment[]
}

model ServiceBay {
    id           String        @id @default(cuid())
    dealershipId String
    bayNumber    Int
    isActive     Boolean       @default(true)
    dealership   Dealership    @relation(fields: [dealershipId], references: [id])
    appointments Appointment[]
}

model Technician {
    id           String        @id @default(cuid())
    dealershipId String
    name         String
    /// JSON-encoded string array of skill identifiers, e.g. '["oil_change","tire_rotation"]'
    skills       String
    dealership   Dealership    @relation(fields: [dealershipId], references: [id])
    appointments Appointment[]
}

model Appointment {
    id            String   @id @default(cuid())
    customerId    String
    vehicleId     String
    serviceTypeId String
    technicianId  String
    serviceBayId  String
    dealershipId  String
    startTime     DateTime
    endTime       DateTime
    /// pending | confirmed | cancelled | completed
    status        String   @default("confirmed")
    createdAt     DateTime @default(now())

    customer    Customer    @relation(fields: [customerId], references: [id])
    vehicle     Vehicle     @relation(fields: [vehicleId], references: [id])
    serviceType ServiceType @relation(fields: [serviceTypeId], references: [id])
    technician  Technician  @relation(fields: [technicianId], references: [id])
    serviceBay  ServiceBay  @relation(fields: [serviceBayId], references: [id])
    dealership  Dealership  @relation(fields: [dealershipId], references: [id])

    @@index([serviceBayId, startTime, endTime])
    @@index([technicianId, startTime, endTime])
    @@index([dealershipId, status])
}
